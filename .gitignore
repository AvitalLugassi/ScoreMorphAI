# ==========================================
# סביבות וירטואליות והתקנות (Python & Node)
# ==========================================
# חוסם את תיקיית .venv שנמצאת בתוך backend
backend/.venv/
**/.venv/
**/venv/
**/env/

# התעלמות מחבילות צד לקוח של ה-frontend (אם יהיו בהמשך)
frontend/node_modules/
**/node_modules/

# ==========================================
# קבצי זכרון מטמון וריצה של פייתון (Python Cache)
# ==========================================
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/*.class
.pytest_cache/
.cache/

# ==========================================
# תיקיות מידע וקבצים זמניים (Data & Outputs)
# ==========================================
# התעלמות מתוכן זמני או כבד בתוך תיקיית data
data/uploads/*
data/separated/*
data/midi/*
data/scores/*
data/temp/*
!data/**/.gitkeep

# התעלמות מתיקיות פלט ולוגים
/output/
/results/
/logs/*
!logs/**/.gitkeep
*.log

# ==========================================
# קבצי שמע כבדים (Audio Files)
# ==========================================
*.mp3
*.wav
*.flac
*.ogg
*.m4a
*.midi
test_files/

# ==========================================
# סביבות עבודה וקבצי מערכת הפעלה (IDEs & OS)
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ==========================================
# קבצי הגדרות רגישים (Environment Variables)
# ==========================================
# חוסם קבצי .env אמיתיים, אך משאיר את .env.example גלוי לגיט
.env
.env.local
.env.*.local